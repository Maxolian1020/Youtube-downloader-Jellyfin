MATCH_WORKERS=3
MATCH_PREFETCH=10
MATCH_CANDIDATES=6
MATCH_CACHE_FIRST=true
RESUME_FROM_DB=true
YTDLP_COOKIES_FILE=/home/youruser/jellyfin-spotify/cookies.txt
YTDLP_COOKIE_FILES=/home/youruser/jellyfin-spotify/cookies_main.txt,/home/youruser/jellyfin-spotify/cookies_alt.txt
YTDLP_SEARCH_SLEEP_SECONDS=0.35
YTDLP_DOWNLOAD_SLEEP_SECONDS=0.7
YTDLP_ATTEMPT_SLEEP_SECONDS=0.2
AUTO_RATE_LIMIT_PAUSE_SECONDS=3600
AUTO_PAUSE_CHECK_SECONDS=15
NORMALIZE_AUDIO=true
LOUDNORM_FILTER=loudnorm=I=-14:TP=-1.5:LRA=11
SPOTIFY_CACHE_DB=/home/youruser/jellyfin-spotify/spotify_cache.db
ENABLE_MUSICBRAINZ=true
MUSICBRAINZ_TIMEOUT_SECONDS=8
MUSICBRAINZ_USER_AGENT=jellyfin-spotify/1.0 (https://localhost; local)
METADATA_MAX_IMAGE_BYTES=5000000
